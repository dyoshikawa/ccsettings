{
  "name": "ccsettings",
  "version": "0.0.0",
  "description": "",
  "keywords": [],
  "homepage": "https://github.com/dyoshikawa/ccsettings#readme",
  "bugs": {
    "url": "https://github.com/dyoshikawa/ccsettings/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dyoshikawa/ccsettings.git"
  },
  "license": "MIT",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "format": "biome format --write .",
    "lint": "npm run lint:biome && npm run lint:oxlint && npm run lint:eslint && npm run lint:type",
    "lint:biome": "biome check --write .",
    "lint:eslint": "eslint .",
    "lint:oxlint": "oxlint -D all",
    "lint:type": "tsc --noEmit",
    "prepare": "simple-git-hooks",
    "test": "vitest",
    "test:cov": "vitest --coverage"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpx lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "secretlint",
      "biome format --write",
      "biome check --write --unsafe"
    ],
    "package.json": [
      "pnpx sort-package-json"
    ]
  },
  "prettier": "@biomejs/biome",
  "devDependencies": {
    "@biomejs/biome": "^2.1.1",
    "@eslint/js": "^9.30.1",
    "@secretlint/secretlint-rule-preset-recommend": "^10.2.0",
    "@typescript/native-preview": "7.0.0-dev.20250710.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.1",
    "lint-staged": "^16.1.2",
    "oxlint": "^1.6.0",
    "secretlint": "^10.2.0",
    "simple-git-hooks": "^2.13.0",
    "sort-package-json": "^3.4.0",
    "tsc-watch": "^7.1.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": ">=20"
  }
}
